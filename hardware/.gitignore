# Generated CAD output (regenerate with: make cad)
cad/out/
*.glb
*.stl
*.step.bak
# Datasheet PDFs (linked in bom/bom.csv — too large to commit)
datasheets/*.pdf
# atopile PCB build output + caches (regenerate with: make pcb)
electrical/pcb/build/
electrical/pcb/.ato/
# Part packages: commit the lightweight defs (footprints/symbols) so the routed
# board + schematic open from a clean clone; keep the heavy binaries out.
electrical/pcb/elec/src/parts/**/*.pdf
electrical/pcb/elec/src/parts/**/*.step
electrical/pcb/elec/src/parts/**/*.stp
electrical/pcb/elec/src/parts/**/*.zip
# NOTE: elec/layout/ is now COMMITTED — it holds the routed PCB + the schematic
# (real manual work, not regenerable by `ato build`). Re-running `make pcb` wipes
# it; the full rebuild is: make pcb → ./route.sh → build_schematic.py.
# uv / python caches
__pycache__/
.venv/
# KiCad fab outputs (regenerate with: ./fab.sh)
electrical/pcb/fab/
