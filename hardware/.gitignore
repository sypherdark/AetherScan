# Generated CAD output (regenerate with: make cad)
cad/out/
*.glb
*.stl
*.step.bak
# Datasheet PDFs (linked in bom/bom.csv — too large to commit)
datasheets/*.pdf
# atopile PCB build output + caches (regenerate with: make pcb)
electrical/pcb/build/
electrical/pcb/.ato/
# Part packages: ignore everything, EXCEPT the hand-created IC parts (made with
# `ato create part` — these are NOT re-fetched by `ato build`, so they must be
# committed). The passive parts are auto-fetched from LCSC on each build.
electrical/pcb/elec/src/parts/*
!electrical/pcb/elec/src/parts/Texas_Instruments_*
# …but keep the big binaries out even of the committed IC parts.
electrical/pcb/elec/src/parts/Texas_Instruments_*/**/*.pdf
electrical/pcb/elec/src/parts/Texas_Instruments_*/**/*.step
electrical/pcb/elec/src/parts/Texas_Instruments_*/**/*.stp
electrical/pcb/elec/src/parts/Texas_Instruments_*/**/*.zip
# Auto-generated layout (no manual placement yet) — start committing this once
# real board placement/routing begins.
electrical/pcb/elec/layout/
# uv / python caches
__pycache__/
.venv/
# KiCad fab outputs (regenerate with: ./fab.sh)
electrical/pcb/fab/
